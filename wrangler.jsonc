{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "jomreview-server-app",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-02",
	"assets": {
		"directory": "./public",
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "mydb",
			"database_id": "9f22b5ab-8647-492e-8b06-4bf33587f78e",
		},
	],
	"observability": {
		"enabled": true,
	},
	"compatibility_flags": ["nodejs_compat"],
}
